# SITE_URL
# Canonical production URL used for site metadata and payment redirects.
SITE_URL=https://yuanjc.net

# DATABASE_URL
# PostgreSQL connection string for Prisma
DATABASE_URL=postgresql://postgres:password@localhost:5432/mywebsite

# PAYPAL
# Use your PayPal business account email. PAYPAL_PAYMENT_LINK is optional.
PAYPAL_EMAIL=payments@avoryne.com
PAYPAL_PAYMENT_LINK=https://www.paypal.com/paypalme/yourname

# BANK TRANSFER
# These details are shown to customers who choose Bank Transfer.
BANK_ACCOUNT_NAME=Avoryne Jewelry
BANK_NAME=Your Bank Name
BANK_ACCOUNT_NUMBER=Your Account Number
BANK_SWIFT=Your SWIFT Code
BANK_IBAN=
BANK_ADDRESS=

# AUTH_SECRET / ADMIN_SECRET
# Generate unique 32+ character random values before deployment.
AUTH_SECRET=replace-with-a-unique-32-character-random-secret
ADMIN_SECRET=replace-with-a-different-32-character-random-secret
